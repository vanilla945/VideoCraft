# ========== API Keys ==========
DEEPSEEK_API_KEY=sk-xxx
KIMI_API_KEY=sk-xxx
MINIMAX_API_KEY=sk-xxx
SILICONFLOW_API_KEY=sk-xxx           # 语音转录（免费，FunAudioLLM/SenseVoiceSmall）

# ========== 四类模型配置 ==========
# 类别 1: 简单快速模型 — 纯文本，高频低复杂度
FAST_MODEL_PROVIDER=deepseek        # deepseek | minimax
FAST_MODEL_NAME=deepseek-v4-flash   # deepseek-v4-flash（纯文本，极致性价比）

# 类别 2: 深度理解模型 — 全模态，文本+视觉一体
HEAVY_MODEL_PROVIDER=minimax        # deepseek | minimax
HEAVY_MODEL_NAME=minimax-m3         # minimax-m3（全模态，文本+视觉通吃）

# 类别 3: TTS 模型（解说配音）
TTS_PROVIDER=local                  # local (Edge-TTS免费) | minimax | deepseek
TTS_MODEL_NAME=edge-tts             # edge-tts | speech-01 | deepseek-tts
TTS_VOICE=zh-CN-XiaoxiaoNeural      # Edge-TTS 音色
TTS_LANGUAGE=zh-CN

# 类别 4: 图像生成模型（封面/B-roll/插图）
IMAGE_PROVIDER=minimax              # minimax | none (关闭)
IMAGE_MODEL_NAME=image-01
IMAGE_MAX_PER_PROJECT=10

# ========== 可选配置 ==========
WHISPER_MODEL=base                  # tiny / base / small / medium / large
